{
  "name": "aiforge-editor-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React + Monaco frontend for the aiforge AI code editor.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
