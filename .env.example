# ---------------------------------------------------------------------------
# aiforge-editor configuration. Copy to .env and fill in as needed.
# Everything runs OFFLINE with the default mock backend — no keys required.
# ---------------------------------------------------------------------------

# Which LLM backend to use: mock | anthropic | huggingface | local
# `mock` is deterministic and offline (default). `local` serves completions
# from the from-scratch model in AIFORGE_LOCAL_MODEL_DIR. The vendor backends
# need keys below.
AIFORGE_BACKEND=mock

# Optional resilience: try providers in order on failure (circuit breaker +
# retries). e.g. anthropic -> huggingface -> mock.
AIFORGE_ENABLE_FAILOVER=false
AIFORGE_BACKEND_FAILOVER=anthropic,huggingface,mock
AIFORGE_LLM_TIMEOUT=60
AIFORGE_LLM_MAX_RETRIES=2

# Route inline completion to our own from-scratch model (keeps chat/edit on the
# configured backend). Set both to enable; falls back to mock if no checkpoint.
AIFORGE_COMPLETE_BACKEND=
AIFORGE_LOCAL_MODEL_DIR=

# Per-feature model overrides (used by the anthropic backend).
AIFORGE_MODEL_COMPLETE=claude-haiku-4-5
AIFORGE_MODEL_CHAT=claude-sonnet-4-6
AIFORGE_MODEL_EDIT=claude-opus-4-8

# ---------------------------------------------------------------------------
# Storage & quotas
# ---------------------------------------------------------------------------
AIFORGE_DATA_DIR=./data
AIFORGE_DATABASE_URL=sqlite:///./data/aiforge.db
# Postgres example:
# AIFORGE_DATABASE_URL=postgresql+psycopg://aiforge:aiforge@localhost:5432/aiforge
AIFORGE_MAX_FILE_BYTES=2000000
AIFORGE_MAX_WORKSPACE_FILES=5000
AIFORGE_MAX_WORKSPACE_BYTES=200000000
AIFORGE_MAX_REQUEST_BYTES=4000000

# ---------------------------------------------------------------------------
# RAG
# ---------------------------------------------------------------------------
AIFORGE_RAG_CHUNK_LINES=60
AIFORGE_RAG_CHUNK_OVERLAP=10
AIFORGE_RAG_TOP_K=6
AIFORGE_RAG_EMBED_DIM=512
AIFORGE_RAG_EMBEDDER=hashing          # hashing | sentence-transformers
AIFORGE_RAG_VECTOR_STORE=numpy        # numpy | qdrant (guarded)
AIFORGE_RAG_PERSIST=true

# ---------------------------------------------------------------------------
# Auth & security
# ---------------------------------------------------------------------------
# Generate a stable secret in production: `openssl rand -hex 32`. If unset, a
# random per-process secret is used (tokens won't survive a restart).
AIFORGE_JWT_SECRET=
AIFORGE_ACCESS_TOKEN_TTL_SECONDS=3600
AIFORGE_REFRESH_TOKEN_TTL_SECONDS=1209600
AIFORGE_ALLOW_REGISTRATION=true
AIFORGE_RATE_LIMIT_RPM=120
AIFORGE_RATE_LIMIT_AI_RPM=30
# Optional Redis for distributed rate limiting (in-memory if empty).
AIFORGE_REDIS_URL=

# ---------------------------------------------------------------------------
# Server / CORS / logging
# ---------------------------------------------------------------------------
AIFORGE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# In production, point this at the built frontend to serve it from "/".
# AIFORGE_FRONTEND_DIST=/app/frontend/dist
AIFORGE_HOST=0.0.0.0
AIFORGE_PORT=8000
AIFORGE_LOG_LEVEL=info
AIFORGE_LOG_JSON=true

# ---------------------------------------------------------------------------
# Vendor API keys — NEVER commit real values. Leave blank to stay offline.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
HF_TOKEN=
